#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

for candidate in \
  "$SCRIPT_DIR/tune.py" \
  "/usr/local/lib/gaokun-ssc-bridge-tuner/tune.py"
do
  if [ -f "$candidate" ]; then
    exec python3 "$candidate" "$@"
  fi
done

echo "ssc-bridge-tune: tune.py not found" >&2
exit 1
